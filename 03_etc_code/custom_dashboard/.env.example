# 이 파일을 복사하여 .env 파일을 만들고, 각 서비스에서 발급받은 키를 입력하세요.

# Discord 채널 웹훅 URL
DISCORD_WEBHOOK_URL=

# X (Twitter) API v2 Keys (https://developer.twitter.com/)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Naver Cafe API (https://developers.naver.com/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_ACCESS_TOKEN= # OAuth 2.0 인증을 통해 얻은 Access Token (주기적 갱신 필요)
NAVER_CAFE_ID= # 글을 게시할 카페 ID
NAVER_MENU_ID= # 글을 게시할 메뉴(게시판) ID